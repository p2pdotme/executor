# Redis is provided by the compose sidecar — do not change this
REDIS_URL=redis://redis:6379

# Alchemy RPC key for Base network
ALCHEMY_API_KEY=

# Diamond contract address on Base
DIAMOND_ADDRESS=

# Discord channel webhooks — one per alert type
DISCORD_ONSUCCESS_WEBHOOK_URL=
DISCORD_ONFAIL_WEBHOOK_URL=
DISCORD_BALANCE_WEBHOOK_URL=

# Funding wallet — auto-tops-up subwallets when balance drops below MIN_BASE_BALANCE_ETH
FUNDING_EXECUTOR=

# Minimum ETH balance before auto-funding kicks in (default 0.005)
MIN_BASE_BALANCE_ETH=0.005

# Set to true to simulate only — no transactions sent (safe for testing against mainnet)
DRY_RUN=true
LOG_LEVEL=debug

# Delay before assigning merchants after OrderPlaced (seconds)
ASSIGN_DELAY_IN_SECONDS=30

# OPTIONAL — executor wallet private keys
# If set: these wallets are used directly on every boot (env is authoritative).
# If not set: wallets are loaded from Redis (or auto-generated on first boot).
# To rotate a wallet: update the env var and redeploy.
TOGGLE_EXECUTOR=
ASSIGN_EXECUTOR=
ORDER_SWEEPER_EXECUTOR=
