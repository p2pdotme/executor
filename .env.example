# Redis is provided by the compose sidecar — do not change this
REDIS_URL=redis://redis:6379

# Alchemy RPC key for Base network
ALCHEMY_API_KEY=

# Diamond contract address on Base
DIAMOND_ADDRESS=

# Telegram — failure alerts
TELEGRAM_ONFAIL_BOT_TOKEN=
TELEGRAM_ONFAIL_CHANNEL_ID=
TELEGRAM_ONFAIL_TOPIC_ID=

# Telegram — success and balance alerts
TELEGRAM_ONSUCCESS_TOPIC_ID=
TELEGRAM_BALANCE_TOPIC_ID=

# Minimum ETH balance on Base before a balance alert fires (default 0.005)
MIN_BASE_BALANCE_ETH=0.005

# Set to true to simulate only — no transactions sent (safe for testing against mainnet)
DRY_RUN=true

# Executor wallets — one private key per responsibility
TOGGLE_EXECUTOR=
ASSIGN_EXECUTOR=
ASSIGN_DELAY_IN_SECONDS=
TOGGLE_SCHEDULE_EXECUTOR=
ORDER_SWEEPER_EXECUTOR=
